<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:context="http://www.springframework.org/schema/context"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd
		http://www.springframework.org/schema/context http://www.springframework.org/schema/context/spring-context-4.3.xsd">

	<context:annotation-config/>
	<bean id="now" class="java.util.Date"/>

	<bean id="myDate" class="java.util.Date">
		<constructor-arg value="2024"/>
		<constructor-arg value="8"/>
		<constructor-arg value="20"/>
	</bean>
	
	<bean id="myDto01" class="com.min.edu.bean03.UserDto">
		<constructor-arg value="여름"/>
		<property name="per" value="a=1 b=2 c=3"/>
		<property name="myDate" ref="myDate"/>
		<property name="hobby" value="없음"/>
	</bean>
	<bean id="myDto02" class="com.min.edu.bean03.UserDto">
		<constructor-arg value="여름"/>
		<property name="per" value="a=1 b=2 c=3"/>
		<property name="myDate" ref="myDate"/>
		<property name="hobby" value="없음"/>
	</bean>
	
	<bean id="userServiceImpl" class="com.min.edu.bean03.UserServiceImpl">
	
	</bean>

</beans>
