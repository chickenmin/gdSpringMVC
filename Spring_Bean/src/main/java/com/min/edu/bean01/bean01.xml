<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

<!-- POJO를 Spring Container에서 사용하기 위해서 bean으로 만들어준다  -->
	<bean id="kenya" class="com.min.edu.bean01.MessageBeanImpl"/>
	
	
	<!--
	오버로딩된 생성자를 통해서 Bean으로 만들어 준다 
	Arguments 입력은 명시적으로 (index) 작성하지 않을 경우 순서대로
	 -->
	<bean id="Americano" class="com.min.edu.bean01.MessageBeanImpl">
		<constructor-arg>
			<value>Americano</value>
		</constructor-arg> 
		<constructor-arg value="2000"/>
	</bean>
		
	<bean id="Arabica" class="com.min.edu.bean01.MessageBeanImpl">
		<constructor-arg index="1" value="Arabica"></constructor-arg>
		<constructor-arg index="0" value="2000"></constructor-arg>
	</bean>
	
</beans>
